<Window x:Class="UsbMicroscopeStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UsbMicroscopeStudio.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USB Microscope Studio"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="USB Microscope Studio" FontSize="18" FontWeight="SemiBold" AutomationProperties.AutomationId="AppTitle" />
                    <TextBlock Text="Phase 2 inspection tools" Foreground="{StaticResource MutedTextBrush}" FontSize="12" AutomationProperties.AutomationId="AppSubtitle" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh" Command="{Binding RefreshCamerasCommand}" AutomationProperties.AutomationId="RefreshCamerasButton" />
                    <Button Content="Start" Command="{Binding StartPreviewCommand}" AutomationProperties.AutomationId="StartPreviewButton" />
                    <Button Content="Stop" Command="{Binding StopPreviewCommand}" AutomationProperties.AutomationId="StopPreviewButton" />
                    <Button Content="Snapshot" Command="{Binding SnapshotCommand}" AutomationProperties.AutomationId="SnapshotButton" />
                    <Button Content="Fullscreen" Command="{Binding ToggleFullscreenCommand}" AutomationProperties.AutomationId="FullscreenButton" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Camera" FontSize="13" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" DisplayMemberPath="DisplayName" AutomationProperties.AutomationId="CameraSelector" />

                        <TextBlock Text="Resolution / FPS" FontSize="13" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" DisplayMemberPath="DisplayName" AutomationProperties.AutomationId="FormatSelector" />

                        <TextBlock Text="Capture" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,8" />
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="Start" Command="{Binding StartPreviewCommand}" AutomationProperties.AutomationId="RailStartPreviewButton" />
                            <Button Content="Stop" Command="{Binding StopPreviewCommand}" AutomationProperties.AutomationId="RailStopPreviewButton" />
                            <Button Content="Snapshot" Command="{Binding SnapshotCommand}" AutomationProperties.AutomationId="RailSnapshotButton" />
                            <Button Content="Fullscreen" Command="{Binding ToggleFullscreenCommand}" AutomationProperties.AutomationId="RailFullscreenButton" />
                        </UniformGrid>

                        <TextBlock Text="Snapshot folder" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,8" />
                        <Button Content="Choose folder" Command="{Binding ChooseSnapshotFolderCommand}" AutomationProperties.AutomationId="ChooseSnapshotFolderButton" />
                        <TextBlock Text="{Binding SnapshotFolderPath}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,14" AutomationProperties.AutomationId="SnapshotFolderPathText" />

                        <TextBlock Text="View" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,8" />
                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <Button Content="-" Command="{Binding ZoomOutCommand}" AutomationProperties.AutomationId="ZoomOutButton" />
                            <Button Content="+" Command="{Binding ZoomInCommand}" AutomationProperties.AutomationId="ZoomInButton" />
                            <Button Content="Reset" Command="{Binding ResetViewCommand}" AutomationProperties.AutomationId="ResetViewButton" />
                        </UniformGrid>

                        <Slider Minimum="0.25" Maximum="4" TickFrequency="0.25" Value="{Binding ZoomLevel}" AutomationProperties.AutomationId="ZoomSlider" />
                        <TextBlock Text="{Binding ZoomLevel, StringFormat=Zoom {0:0.00}x}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,16" AutomationProperties.AutomationId="ZoomReadout" />

                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="Rotate Left" Command="{Binding RotateLeftCommand}" AutomationProperties.AutomationId="RotateLeftButton" />
                            <Button Content="Rotate Right" Command="{Binding RotateRightCommand}" AutomationProperties.AutomationId="RotateRightButton" />
                        </UniformGrid>

                        <CheckBox Content="Mirror horizontal" IsChecked="{Binding IsMirrored}" Margin="0,8,0,8" AutomationProperties.AutomationId="MirrorToggle" />
                        <CheckBox Content="Freeze preview" IsChecked="{Binding IsFrozen}" Margin="0,0,0,18" AutomationProperties.AutomationId="FreezeToggle" />

                        <TextBlock Text="Inspection" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,8" />
                        <CheckBox Content="Freeze &amp; Inspect" IsChecked="{Binding IsFreezeInspectMode}" Margin="0,0,0,8" AutomationProperties.AutomationId="FreezeInspectToggle" />
                        <CheckBox Content="Crosshair" IsChecked="{Binding ShowCrosshair}" Margin="0,0,0,4" AutomationProperties.AutomationId="CrosshairToggle" />
                        <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Margin="0,0,0,4" AutomationProperties.AutomationId="GridToggle" />
                        <Slider Minimum="8" Maximum="240" TickFrequency="8" Value="{Binding GridSpacingPixels}" AutomationProperties.AutomationId="GridSpacingSlider" />
                        <CheckBox Content="Rulers" IsChecked="{Binding ShowRulers}" Margin="0,4,0,10" AutomationProperties.AutomationId="RulersToggle" />

                        <TextBlock Text="Annotation tool" FontSize="13" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding ToolChoices}" SelectedItem="{Binding CurrentTool}" AutomationProperties.AutomationId="AnnotationToolSelector" />
                        <TextBlock Text="Color" FontSize="13" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding StrokeColors}" SelectedItem="{Binding SelectedStrokeColor}" AutomationProperties.AutomationId="StrokeColorSelector" />
                        <TextBlock Text="Stroke thickness" FontSize="13" FontWeight="SemiBold" />
                        <Slider Minimum="1" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SelectedStrokeThickness}" AutomationProperties.AutomationId="StrokeThicknessSlider" />
                        <UniformGrid Columns="3" Margin="0,10,0,14">
                            <Button Content="Undo" Command="{Binding UndoAnnotationsCommand}" AutomationProperties.AutomationId="UndoAnnotationsButton" />
                            <Button Content="Redo" Command="{Binding RedoAnnotationsCommand}" AutomationProperties.AutomationId="RedoAnnotationsButton" />
                            <Button Content="Clear" Command="{Binding ClearAnnotationsCommand}" AutomationProperties.AutomationId="ClearAnnotationsButton" />
                        </UniformGrid>

                        <TextBlock Text="Calibration" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CalibrationStatus}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,8" AutomationProperties.AutomationId="CalibrationStatusText" />
                        <ComboBox ItemsSource="{Binding VisibleCalibrationProfiles}" SelectedItem="{Binding SelectedCalibrationProfile}" DisplayMemberPath="Name" AutomationProperties.AutomationId="CalibrationProfileSelector" />
                        <TextBox Text="{Binding CalibrationProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" AutomationProperties.AutomationId="CalibrationProfileNameTextBox" />
                        <TextBox Text="{Binding KnownCalibrationLength, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" AutomationProperties.AutomationId="KnownCalibrationLengthTextBox" />
                        <ComboBox ItemsSource="{Binding UnitChoices}" SelectedItem="{Binding SelectedUnits}" AutomationProperties.AutomationId="CalibrationUnitsSelector" />
                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <Button Content="Create" Command="{Binding CreateCalibrationProfileCommand}" AutomationProperties.AutomationId="CreateCalibrationProfileButton" />
                            <Button Content="Rename" Command="{Binding RenameCalibrationProfileCommand}" AutomationProperties.AutomationId="RenameCalibrationProfileButton" />
                            <Button Content="Delete" Command="{Binding DeleteCalibrationProfileCommand}" AutomationProperties.AutomationId="DeleteCalibrationProfileButton" />
                        </UniformGrid>
                        <TextBlock Text="{Binding MeasurementStatus}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" AutomationProperties.AutomationId="MeasurementStatusText" />
                        <UniformGrid Columns="2" Margin="0,0,0,14">
                            <Button Content="Save clean" Command="{Binding SaveCleanFrameCommand}" AutomationProperties.AutomationId="SaveCleanFrameButton" />
                            <Button Content="Save annotated" Click="SaveAnnotatedFrame_Click" AutomationProperties.AutomationId="SaveAnnotatedFrameButton" />
                            <Button Content="Open inspection" Click="OpenInspection_Click" AutomationProperties.AutomationId="OpenInspectionButton" />
                            <Button Content="Save JSON" Command="{Binding SaveInspectionSidecarCommand}" AutomationProperties.AutomationId="SaveInspectionSidecarButton" />
                        </UniformGrid>

                        <Border BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12" Background="#FAFBFC">
                            <StackPanel>
                                <TextBlock Text="Session" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentFps, StringFormat=FPS {0:0.0}}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" AutomationProperties.AutomationId="FpsReadout" />
                                <TextBlock Text="{Binding RotationDegrees, StringFormat=Rotation {0} deg}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" AutomationProperties.AutomationId="RotationReadout" />
                                <TextBlock Text="{Binding LastSnapshotPath}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" AutomationProperties.AutomationId="LastSnapshotPath" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid x:Name="PreviewHost" Grid.Column="1" Background="#202326" ClipToBounds="True" AutomationProperties.AutomationId="PreviewHost">
                <Viewbox Stretch="Uniform" AutomationProperties.AutomationId="PreviewViewbox">
                    <Viewbox.RenderTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                    </Viewbox.RenderTransform>
                    <Viewbox.RenderTransformOrigin>0.5,0.5</Viewbox.RenderTransformOrigin>
                    <Grid Width="{Binding PreviewWidth}" Height="{Binding PreviewHeight}">
                        <Image Source="{Binding PreviewFrame}" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality" AutomationProperties.AutomationId="LivePreviewImage" />
                        <controls:InspectionOverlayControl
                            Width="{Binding PreviewWidth}"
                            Height="{Binding PreviewHeight}"
                            Annotations="{Binding Annotations}"
                            CurrentTool="{Binding CurrentTool}"
                            StrokeColor="{Binding SelectedStrokeColor}"
                            StrokeThickness="{Binding SelectedStrokeThickness}"
                            ShowCrosshair="{Binding ShowCrosshair}"
                            ShowGrid="{Binding ShowGrid}"
                            GridSpacingPixels="{Binding GridSpacingPixels}"
                            ShowRulers="{Binding ShowRulers}"
                            CaptureHistoryCommand="{Binding CaptureAnnotationHistoryCommand}"
                            AutomationProperties.AutomationId="InspectionOverlayCanvas" />
                    </Grid>
                </Viewbox>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" AutomationProperties.AutomationId="StatusText" />
        </Border>
    </Grid>
</Window>
