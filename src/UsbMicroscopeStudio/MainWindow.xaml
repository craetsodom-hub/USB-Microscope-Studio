<Window x:Class="UsbMicroscopeStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UsbMicroscopeStudio.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USB Microscope Studio"
        Width="960"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="84" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0D131A" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="USB Microscope Studio" FontSize="18" FontWeight="SemiBold" AutomationProperties.AutomationId="AppTitle" />
                    <TextBlock Text="Professional microscope inspection workspace" Style="{StaticResource MutedTextStyle}" AutomationProperties.AutomationId="AppSubtitle" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="28,0,0,0">
                    <Button Content="Refresh" Command="{Binding RefreshCamerasCommand}" Style="{StaticResource CompactCommandButtonStyle}" AutomationProperties.AutomationId="RefreshCamerasButton" />
                    <Button Content="Start" Command="{Binding StartPreviewCommand}" Style="{StaticResource CompactPrimaryCommandButtonStyle}" AutomationProperties.AutomationId="StartPreviewButton" />
                    <Button Content="Stop" Command="{Binding StopPreviewCommand}" Style="{StaticResource CompactCommandButtonStyle}" AutomationProperties.AutomationId="StopPreviewButton" />
                    <Button Content="Capture" Command="{Binding SnapshotCommand}" Style="{StaticResource CompactCommandButtonStyle}" AutomationProperties.AutomationId="SnapshotButton" />
                    <Button Content="Fullscreen" Command="{Binding ToggleFullscreenCommand}" Style="{StaticResource CompactCommandButtonStyle}" AutomationProperties.AutomationId="FullscreenButton" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#101821" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1" Padding="22,7">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SessionDisplay}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="320" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <StackPanel>
                            <TextBlock Text="Calibration" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding CalibrationStatus}" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <StackPanel>
                            <TextBlock Text="Session" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding CurrentSessionJsonDisplay}" FontSize="12" MaxWidth="180" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <StackPanel>
                            <TextBlock Text="Report" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Text="{Binding LastReportDisplay}" FontSize="12" MaxWidth="180" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="0,5,0,0">
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <TextBlock Text="{Binding CustomerDisplay, StringFormat=Customer: {0}}" Style="{StaticResource MutedTextStyle}" />
                    </Border>
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <TextBlock Text="{Binding DeviceDisplay, StringFormat=Device: {0}}" Style="{StaticResource MutedTextStyle}" />
                    </Border>
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <TextBlock Text="{Binding SelectedCamera.DisplayName, StringFormat=Camera: {0}, TargetNullValue=Camera: None}" Style="{StaticResource MutedTextStyle}" />
                    </Border>
                    <Border Style="{StaticResource HeaderBadgeStyle}">
                        <TextBlock Text="{Binding SelectedFormat.DisplayName, StringFormat=Format: {0}, TargetNullValue=Format: None}" Style="{StaticResource MutedTextStyle}" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="348" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Padding="10" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Inspection Controls" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Camera, sessions, tools, reports" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" Margin="0">
                            <TextBlock Text="{Binding CurrentFps, StringFormat=FPS {0:0.0}}" Style="{StaticResource MutedTextStyle}" AutomationProperties.AutomationId="FpsReadout" />
                        </Border>
                    </Grid>

                    <TabControl Grid.Row="1">
                        <TabItem Header="Camera">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Source" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="Camera" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" DisplayMemberPath="DisplayName" AutomationProperties.AutomationId="CameraSelector" />
                                            <TextBlock Text="Resolution / FPS" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" DisplayMemberPath="DisplayName" AutomationProperties.AutomationId="FormatSelector" />
                                            <UniformGrid Columns="3" Margin="0,8,0,0">
                                                <Button Content="Start" Command="{Binding StartPreviewCommand}" Style="{StaticResource PrimaryButtonStyle}" AutomationProperties.AutomationId="RailStartPreviewButton" />
                                                <Button Content="Stop" Command="{Binding StopPreviewCommand}" AutomationProperties.AutomationId="RailStopPreviewButton" />
                                                <Button Content="Refresh" Command="{Binding RefreshCamerasCommand}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Capture" Style="{StaticResource SectionTitleStyle}" />
                                            <UniformGrid Columns="2">
                                                <Button Content="Capture" Command="{Binding SnapshotCommand}" AutomationProperties.AutomationId="RailSnapshotButton" />
                                                <Button Content="Fullscreen" Command="{Binding ToggleFullscreenCommand}" AutomationProperties.AutomationId="RailFullscreenButton" />
                                            </UniformGrid>
                                            <TextBlock Text="Capture folder" Style="{StaticResource FieldLabelStyle}" />
                                            <Button Content="Choose folder" Command="{Binding ChooseSnapshotFolderCommand}" AutomationProperties.AutomationId="ChooseSnapshotFolderButton" />
                                            <TextBlock Text="{Binding SnapshotFolderDisplay}" ToolTip="{Binding SnapshotFolderPath}" TextTrimming="CharacterEllipsis" Style="{StaticResource MutedTextStyle}" Margin="3,4,3,0" AutomationProperties.AutomationId="SnapshotFolderPathText" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="View" Style="{StaticResource SectionTitleStyle}" />
                                            <UniformGrid Columns="3">
                                                <Button Content="-" Command="{Binding ZoomOutCommand}" AutomationProperties.AutomationId="ZoomOutButton" />
                                                <Button Content="+" Command="{Binding ZoomInCommand}" AutomationProperties.AutomationId="ZoomInButton" />
                                                <Button Content="Reset" Command="{Binding ResetViewCommand}" AutomationProperties.AutomationId="ResetViewButton" />
                                            </UniformGrid>
                                            <Slider Minimum="0.25" Maximum="4" TickFrequency="0.25" Value="{Binding ZoomLevel}" AutomationProperties.AutomationId="ZoomSlider" />
                                            <TextBlock Text="{Binding ZoomLevel, StringFormat=Zoom {0:0.00}x}" Style="{StaticResource MutedTextStyle}" AutomationProperties.AutomationId="ZoomReadout" />
                                            <UniformGrid Columns="2" Margin="0,10,0,2">
                                                <Button Content="Rotate Left" Command="{Binding RotateLeftCommand}" AutomationProperties.AutomationId="RotateLeftButton" />
                                                <Button Content="Rotate Right" Command="{Binding RotateRightCommand}" AutomationProperties.AutomationId="RotateRightButton" />
                                            </UniformGrid>
                                            <CheckBox Content="Mirror horizontal" IsChecked="{Binding IsMirrored}" AutomationProperties.AutomationId="MirrorToggle" />
                                            <CheckBox Content="Freeze preview" IsChecked="{Binding IsFrozen}" AutomationProperties.AutomationId="FreezeToggle" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Session">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Session" Style="{StaticResource SectionTitleStyle}" />
                                            <UniformGrid Columns="2">
                                                <Button Content="New" Command="{Binding NewSessionCommand}" AutomationProperties.AutomationId="NewSessionButton" />
                                                <Button Content="Save Session" Command="{Binding SaveSessionCommand}" Style="{StaticResource PrimaryButtonStyle}" AutomationProperties.AutomationId="SaveSessionButton" />
                                                <Button Content="Save As" Command="{Binding SaveSessionAsCommand}" AutomationProperties.AutomationId="SaveSessionAsButton" />
                                                <Button Content="Open" Click="OpenSession_Click" AutomationProperties.AutomationId="OpenSessionButton" />
                                            </UniformGrid>
                                            <TextBlock Text="Recent sessions" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding RecentSessions}" SelectedItem="{Binding SelectedRecentSession}" DisplayMemberPath="DisplayName" AutomationProperties.AutomationId="RecentSessionsSelector" />
                                            <Button Content="Open recent" Command="{Binding OpenRecentSessionCommand}" AutomationProperties.AutomationId="OpenRecentSessionButton" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Metadata" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="Project name" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="SessionNameTextBox" />
                                            <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="CustomerNameTextBox" />
                                            <TextBlock Text="Device model" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding DeviceModel, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="DeviceModelTextBox" />
                                            <TextBlock Text="Serial / asset tag" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SerialAssetTag, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="SerialAssetTagTextBox" />
                                            <TextBlock Text="Technician" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="TechnicianNameTextBox" />
                                            <TextBlock Text="Job / order number" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding JobOrderNumber, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="JobOrderNumberTextBox" />
                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SessionNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="82" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AutomationProperties.AutomationId="SessionNotesTextBox" />
                                            <TextBlock Text="{Binding CurrentSessionFolderDisplay}" ToolTip="{Binding CurrentSessionFolderPath}" TextTrimming="CharacterEllipsis" Style="{StaticResource MutedTextStyle}" Margin="3,10,3,0" AutomationProperties.AutomationId="CurrentSessionFolderText" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Inspect">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Overlay" Style="{StaticResource SectionTitleStyle}" />
                                            <CheckBox Content="Freeze &amp; Inspect" IsChecked="{Binding IsFreezeInspectMode}" AutomationProperties.AutomationId="FreezeInspectToggle" />
                                            <CheckBox Content="Crosshair" IsChecked="{Binding ShowCrosshair}" AutomationProperties.AutomationId="CrosshairToggle" />
                                            <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" AutomationProperties.AutomationId="GridToggle" />
                                            <Slider Minimum="8" Maximum="240" TickFrequency="8" Value="{Binding GridSpacingPixels}" AutomationProperties.AutomationId="GridSpacingSlider" />
                                            <CheckBox Content="Rulers" IsChecked="{Binding ShowRulers}" AutomationProperties.AutomationId="RulersToggle" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Annotations" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="Annotation tool" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding ToolChoices}" SelectedItem="{Binding CurrentTool}" AutomationProperties.AutomationId="AnnotationToolSelector" />
                                            <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding StrokeColors}" SelectedItem="{Binding SelectedStrokeColor}" AutomationProperties.AutomationId="StrokeColorSelector" />
                                            <TextBlock Text="Stroke thickness" Style="{StaticResource FieldLabelStyle}" />
                                            <Slider Minimum="1" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SelectedStrokeThickness}" AutomationProperties.AutomationId="StrokeThicknessSlider" />
                                            <UniformGrid Columns="3" Margin="0,10,0,0">
                                                <Button Content="Undo" Command="{Binding UndoAnnotationsCommand}" AutomationProperties.AutomationId="UndoAnnotationsButton" />
                                                <Button Content="Redo" Command="{Binding RedoAnnotationsCommand}" AutomationProperties.AutomationId="RedoAnnotationsButton" />
                                                <Button Content="Clear" Command="{Binding ClearAnnotationsCommand}" Style="{StaticResource DangerButtonStyle}" AutomationProperties.AutomationId="ClearAnnotationsButton" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Inspection Saves" Style="{StaticResource SectionTitleStyle}" />
                                            <UniformGrid Columns="2">
                                                <Button Content="Save clean" Command="{Binding SaveCleanFrameCommand}" AutomationProperties.AutomationId="SaveCleanFrameButton" />
                                                <Button Content="Save annotated" Click="SaveAnnotatedFrame_Click" AutomationProperties.AutomationId="SaveAnnotatedFrameButton" />
                                                <Button Content="Open inspection" Click="OpenInspection_Click" AutomationProperties.AutomationId="OpenInspectionButton" />
                                                <Button Content="Save JSON" Command="{Binding SaveInspectionSidecarCommand}" AutomationProperties.AutomationId="SaveInspectionSidecarButton" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Calibration">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Calibration Profile" Style="{StaticResource SectionTitleStyle}" />
                                            <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding CalibrationStatus}" TextWrapping="Wrap" AutomationProperties.AutomationId="CalibrationStatusText" />
                                            </Border>
                                            <TextBlock Text="Profile" Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <ComboBox ItemsSource="{Binding VisibleCalibrationProfiles}" SelectedItem="{Binding SelectedCalibrationProfile}" DisplayMemberPath="Name" IsEnabled="{Binding HasVisibleCalibrationProfiles}" AutomationProperties.AutomationId="CalibrationProfileSelector" />
                                                <Border Background="{StaticResource FieldBrush}"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8,5"
                                                        IsHitTestVisible="False"
                                                        Visibility="{Binding HasNoVisibleCalibrationProfiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="No saved profiles" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="Profile name" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding CalibrationProfileName, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="CalibrationProfileNameTextBox" />
                                            <TextBlock Text="Known length" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding KnownCalibrationLength, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="KnownCalibrationLengthTextBox" />
                                            <TextBlock Text="Units" Style="{StaticResource FieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding UnitChoices}" SelectedItem="{Binding SelectedUnits}" AutomationProperties.AutomationId="CalibrationUnitsSelector" />
                                            <UniformGrid Columns="3" Margin="0,10,0,0">
                                                <Button Content="Create" Command="{Binding CreateCalibrationProfileCommand}" Style="{StaticResource PrimaryButtonStyle}" AutomationProperties.AutomationId="CreateCalibrationProfileButton" />
                                                <Button Content="Rename" Command="{Binding RenameCalibrationProfileCommand}" IsEnabled="{Binding HasSelectedCalibrationProfile}" AutomationProperties.AutomationId="RenameCalibrationProfileButton" />
                                                <Button Content="Delete" Command="{Binding DeleteCalibrationProfileCommand}" IsEnabled="{Binding HasSelectedCalibrationProfile}" Style="{StaticResource DangerButtonStyle}" AutomationProperties.AutomationId="DeleteCalibrationProfileButton" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Measurement" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding MeasurementStatus}" TextWrapping="Wrap" AutomationProperties.AutomationId="MeasurementStatusText" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Export">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="HTML Report" Style="{StaticResource SectionTitleStyle}" />
                                            <UniformGrid Columns="2">
                                                <Button Content="Export Report" Command="{Binding ExportHtmlReportCommand}" Style="{StaticResource PrimaryButtonStyle}" AutomationProperties.AutomationId="ExportHtmlReportButton" />
                                                <Button Content="Open Last Report" Command="{Binding OpenLastReportCommand}" AutomationProperties.AutomationId="OpenLastReportButton" />
                                            </UniformGrid>
                                            <TextBlock Text="Last report" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding LastReportFileDisplay}" ToolTip="{Binding LastReportPath}" TextTrimming="CharacterEllipsis" Style="{StaticResource MutedTextStyle}" AutomationProperties.AutomationId="LastReportPathText" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Artifacts" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding LastSnapshotFileDisplay}" ToolTip="{Binding LastSnapshotPath}" TextTrimming="CharacterEllipsis" Style="{StaticResource MutedTextStyle}" AutomationProperties.AutomationId="LastSnapshotPath" />
                                            <TextBlock Text="{Binding RotationDisplay}" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" AutomationProperties.AutomationId="RotationReadout" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#070B10" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="7" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="#0E151D" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Live Preview" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource StatusBadgeStyle}">
                                    <TextBlock Text="{Binding ZoomLevel, StringFormat=Zoom {0:0.00}x}" Style="{StaticResource MutedTextStyle}" />
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}">
                                    <TextBlock Text="{Binding RotationDisplay}" Style="{StaticResource MutedTextStyle}" />
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}" Margin="0">
                                    <TextBlock Text="{Binding MeasurementChipDisplay}" Style="{StaticResource MutedTextStyle}" />
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}" Margin="0">
                                    <TextBlock Text="{Binding CalibrationChipDisplay}" Style="{StaticResource MutedTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="PreviewHost" Grid.Row="1" ClipToBounds="True" AutomationProperties.AutomationId="PreviewHost">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#171D23" Offset="0" />
                                <GradientStop Color="#0B1015" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Viewbox Stretch="Uniform" AutomationProperties.AutomationId="PreviewViewbox">
                            <Viewbox.RenderTransform>
                                <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                            </Viewbox.RenderTransform>
                            <Viewbox.RenderTransformOrigin>0.5,0.5</Viewbox.RenderTransformOrigin>
                            <Grid Width="{Binding PreviewWidth}" Height="{Binding PreviewHeight}">
                                <Image Source="{Binding PreviewFrame}" Stretch="None" IsHitTestVisible="False" RenderOptions.BitmapScalingMode="HighQuality" AutomationProperties.AutomationId="LivePreviewImage" />
                                <Border Panel.ZIndex="1" Background="Transparent">
                                    <controls:InspectionOverlayControl
                                        Width="{Binding PreviewWidth}"
                                        Height="{Binding PreviewHeight}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Annotations="{Binding Annotations}"
                                        CurrentTool="{Binding CurrentTool}"
                                        StrokeColor="{Binding SelectedStrokeColor}"
                                        StrokeThickness="{Binding SelectedStrokeThickness}"
                                        ShowCrosshair="{Binding ShowCrosshair}"
                                        ShowGrid="{Binding ShowGrid}"
                                        GridSpacingPixels="{Binding GridSpacingPixels}"
                                        ShowRulers="{Binding ShowRulers}"
                                        CaptureHistoryCommand="{Binding CaptureAnnotationHistoryCommand}"
                                        AutomationProperties.AutomationId="InspectionOverlayCanvas" />
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0D131A" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Status" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0" />
                <TextBlock Grid.Column="1" Text="{Binding StatusSummary}" ToolTip="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" AutomationProperties.AutomationId="StatusText" />
                <TextBlock Grid.Column="2" Text="{Binding SessionStatusDisplay, StringFormat=Session: {0}}" ToolTip="{Binding CurrentSessionFolderPath}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="300" />
            </Grid>
        </Border>
    </Grid>
</Window>

